DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mail_queue

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=mail_queue
RABBITMQ_POOL_SIZE=10

NORMAL_PRIORITY_MAX_RATE=10
HIGH_PRIORITY_THRESHOLD=4

AGING_THRESHOLD_SECONDS=300
AGING_PROMOTION_PRIORITY=5
HIGH_PRIORITY_BACKLOG_THRESHOLD=1000

BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_MAX_SIZE=100
BATCH_UPDATE_INTERVAL_MS=500
